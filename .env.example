# ============================================================================
# Brainiac Hub — Variaveis de Ambiente
# ============================================================================

# API Claude (Anthropic) — necessario para funcionalidades de IA
ANTHROPIC_API_KEY=sk-ant-api03-SUA_CHAVE_AQUI

# ============================================================================
# Google Sheets — Torre de Comando (leitura E escrita)
# ============================================================================
# ID da planilha Torre de Comando 2.0
GOOGLE_SHEETS_ID=SEU_SPREADSHEET_ID_AQUI

# ID da planilha Squad TER - Margem Ops (dados financeiros)
GOOGLE_SHEETS_FINANCIAL_ID=SEU_FINANCIAL_SPREADSHEET_ID_AQUI

# Autenticacao Google:
# OPCAO 1: API Key (somente leitura)
GOOGLE_API_KEY=SUA_GOOGLE_API_KEY_AQUI

# OPCAO 2: Service Account (leitura + escrita) - RECOMENDADO
# Coloque o arquivo google-credentials.json na raiz do projeto
# e compartilhe a planilha com o email da Service Account
GOOGLE_SERVICE_ACCOUNT_FILE=google-credentials.json

# AMBIENTE
NODE_ENV=production

# PORTA — Geralmente 3000 para Node.js
PORT=3000

# ============================================================================
# API Bridge — Integracao com agentes externos (Meet Agent)
# ============================================================================
BRAINIAC_API_KEY=sua-chave-secreta-aqui
BRAINIAC_API_PORT=3847
