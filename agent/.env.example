# Google OAuth2 (obter em https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx

# Brainiac API Bridge
BRAINIAC_URL=http://localhost:3847
BRAINIAC_API_KEY=mesma-chave-do-brainiac

# Intervalo de verificação em minutos (modo --watch)
AGENT_CHECK_INTERVAL_MINUTES=30
